{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HASmartCharge.Backend": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=hasmartcharge.db"
  },
  "AllowedHosts": "*",
  "HomeAssistantAuth": {
    "StateExpirationMinutes": 10
  },
  "Ocpp": {
    "RawFrameLog": {
      "Enabled": false,
      "Path": "ocpp-raw.log"
    }
  }
}
