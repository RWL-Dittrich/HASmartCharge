{
  "Logging": {
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffZ ",
        "UseUtcTimestamp": true
      }
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "HASmartCharge.Backend": "Information",
      "HASmartCharge.Backend.OCPP.Domain.ChargePointSession": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient.Default": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=hasmartcharge.db"
  },
  "AllowedHosts": "*",
  "HomeAssistantAuth": {
    "StateExpirationMinutes": 10
  },
  "Ocpp": {
    "RawFrameLog": {
      "Enabled": false,
      "Path": "ocpp-raw.log"
    }
  }
}
